{
  "name": "@vineethnkrishnan/google-workspace-mcp",
  "version": "0.1.5",
  "description": "An MCP server for Google Workspace APIs (Gmail, Calendar, Drive, Sheets), enabling AI assistants to search emails, check calendars, find files, and read spreadsheets.",
  "mcpName": "io.github.vineethkrishnan/google-workspace-mcp",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "google-workspace-mcp": "build/index.js"
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "test": "jest --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "google-workspace",
    "gmail",
    "google-calendar",
    "google-drive",
    "google-sheets",
    "ai",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vineethkrishnan/mcp-pool.git",
    "directory": "packages/google-workspace"
  },
  "homepage": "https://github.com/vineethkrishnan/mcp-pool/tree/main/packages/google-workspace#readme",
  "bugs": {
    "url": "https://github.com/vineethkrishnan/mcp-pool/issues"
  },
  "author": "Vineeth Krishnan",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vineethnkrishnan/oauth-core": "*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.7.0"
  }
}

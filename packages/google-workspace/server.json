{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vineethkrishnan/google-workspace-mcp",
  "description": "A read-only MCP server for Google Workspace APIs (Gmail, Calendar, Drive, Sheets), enabling AI assistants to search emails, check calendars, find files, and read spreadsheets.",
  "repository": {
    "url": "https://github.com/vineethkrishnan/mcp-pool",
    "source": "github",
    "subfolder": "packages/google-workspace"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vineethnkrishnan/google-workspace-mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Google OAuth client ID",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "GOOGLE_CLIENT_ID"
        },
        {
          "description": "Google OAuth client secret",
          "isRequired": false,
          "format": "string",
          "isSecret": true,
          "name": "GOOGLE_CLIENT_SECRET"
        }
      ]
    }
  ]
}

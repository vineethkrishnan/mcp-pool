{
  "name": "@vineethnkrishnan/notion-mcp",
  "version": "0.1.2",
  "description": "A read-only MCP server for the Notion API, enabling AI assistants to search, read pages, query databases, and list users.",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "bin": {
    "notion-mcp": "build/index.js"
  },
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "test": "jest --coverage"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "notion",
    "ai",
    "model-context-protocol",
    "knowledge-base",
    "wiki",
    "databases"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vineethkrishnan/mcp-pool.git",
    "directory": "packages/notion"
  },
  "homepage": "https://github.com/vineethkrishnan/mcp-pool/tree/main/packages/notion#readme",
  "bugs": {
    "url": "https://github.com/vineethkrishnan/mcp-pool/issues"
  },
  "author": "Vineeth Krishnan",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vineethnkrishnan/oauth-core": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.0"
  }
}

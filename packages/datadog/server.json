{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vineethkrishnan/datadog-mcp",
  "description": "An MCP server for Datadog API, enabling AI assistants to query monitors, metrics, and events. Supports all Datadog regions.",
  "repository": {
    "url": "https://github.com/vineethkrishnan/mcp-pool",
    "source": "github",
    "subfolder": "packages/datadog"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vineethnkrishnan/datadog-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Datadog API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "DD_API_KEY"
        },
        {
          "description": "Datadog application key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "DD_APP_KEY"
        },
        {
          "description": "Datadog site (e.g. datadoghq.com, datadoghq.eu)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "DD_SITE"
        }
      ]
    }
  ]
}

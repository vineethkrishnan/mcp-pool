{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vineethkrishnan/shopify-mcp",
  "description": "An MCP server for Shopify Admin API, enabling AI assistants to query orders, products, customers, and store info.",
  "repository": {
    "url": "https://github.com/vineethkrishnan/mcp-pool",
    "source": "github",
    "subfolder": "packages/shopify"
  },
  "version": "0.1.3",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vineethnkrishnan/shopify-mcp",
      "version": "0.1.3",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Shopify store URL (e.g. my-store.myshopify.com)",
          "isRequired": true,
          "format": "string",
          "isSecret": false,
          "name": "SHOPIFY_STORE_URL"
        }
      ]
    }
  ]
}
{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vineethkrishnan/pagerduty-mcp",
  "description": "An MCP server for PagerDuty API, enabling AI assistants to query incidents, services, and on-call schedules.",
  "repository": {
    "url": "https://github.com/vineethkrishnan/mcp-pool",
    "source": "github",
    "subfolder": "packages/pagerduty"
  },
  "version": "0.1.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vineethnkrishnan/pagerduty-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "PagerDuty API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "PAGERDUTY_API_KEY"
        },
        {
          "description": "PagerDuty API base URL (for EU or custom instances)",
          "isRequired": false,
          "format": "string",
          "isSecret": false,
          "name": "PAGERDUTY_BASE_URL"
        }
      ]
    }
  ]
}

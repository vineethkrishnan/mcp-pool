{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.vineethkrishnan/stripe-mcp",
  "description": "An MCP server for Stripe API, enabling AI assistants to query financial data.",
  "repository": {
    "url": "https://github.com/vineethkrishnan/mcp-pool",
    "source": "github",
    "subfolder": "packages/stripe"
  },
  "version": "1.0.7",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@vineethnkrishnan/stripe-mcp",
      "version": "1.0.7",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Stripe secret API key",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "STRIPE_SECRET_KEY"
        }
      ]
    }
  ]
}

{
  "name": "@vineethnkrishnan/mcp-pool",
  "private": true,
  "description": "A centralized pool of Model Context Protocol (MCP) servers.",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "npm run build -w packages/oauth-core && npm run build --workspaces --if-present",
    "test": "npm run build -w packages/oauth-core && npm test --workspaces --if-present",
    "lint:check": "eslint packages/",
    "lint:fix": "eslint --fix packages/",
    "format": "prettier --write \"packages/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/*.ts\"",
    "docs:start": "npm start --workspace docs",
    "docs:build": "npm run build --workspace docs",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "stripe"
  ],
  "author": "Vineeth Krishnan",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "overrides": {
    "ws": "^8.20.1",
    "qs": "^6.15.2",
    "uuid": "^11.1.1",
    "serialize-javascript": "^7.0.5",
    "webpack-dev-server": "^5.2.4",
    "@babel/plugin-transform-modules-systemjs": "^7.29.4",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "@hono/node-server": "^1.19.13",
    "ip-address": "^10.1.1",
    "postcss": "^8.5.10",
    "follow-redirects": "^1.16.0",
    "lodash": "^4.18.0"
  }
}
